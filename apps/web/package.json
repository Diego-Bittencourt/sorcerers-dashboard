{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/types": ["../types"],
      "@repo/utils": ["../utils"]
    }
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "nuxt": "^3.15.0",
    "vue": "latest",
    "vue-router": "latest",
    "@repo/utils": "workspace:*"
  }
}
