{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "@repo/utils#build": {
      "outputs": ["packages/utils/dist/**"]
    },
    "api#build": {
      "outputs": ["apps/api/dist/**"]
    },
    "nuxt-app#build": {
      "outputs": [".nuxt/**"]
    },
    "lint": {
      "outputs": []
    },
    "check-types": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
